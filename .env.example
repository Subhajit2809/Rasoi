# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for absolute URLs in OG meta tags.
# In Vercel this is set automatically via VERCEL_URL (see next.config.ts).
# For local development, leave blank — localhost is used as fallback.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Sentry (optional) ────────────────────────────────────────────────────────
# Error tracking — leave blank to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── PostHog (optional) ──────────────────────────────────────────────────────
# Product analytics — leave blank to disable PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Google Gemini (optional) ────────────────────────────────────────────────
# AI Vision for Photo-to-Fridge feature — get a free key at https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=

# ─── Setup checklist ──────────────────────────────────────────────────────────
# 1. Copy this file to .env.local and fill in real values.
# 2. In your Supabase project:
#    a. Enable Google OAuth under Authentication → Providers → Google.
#    b. Add your Vercel deployment URL to Authentication → URL Configuration:
#       Site URL:        https://your-app.vercel.app
#       Redirect URLs:   https://your-app.vercel.app/auth/callback
#    c. Run the SQL migrations in supabase/migrations/ (in order).
#    d. Run the seed file: supabase/seed.sql
# 3. In Vercel dashboard → Settings → Environment Variables, add:
#    NEXT_PUBLIC_SUPABASE_URL
#    NEXT_PUBLIC_SUPABASE_ANON_KEY
#    NEXT_PUBLIC_APP_URL  (set to your production domain)
